# ARIA Environment Variables

# === LLM (Ollama — local, free) ===
# Heavy model for reasoning (synthesis, contradictions, chat, explain, roadmap)
OLLAMA_MODEL=gemma3:12b
# Fast model for extraction (~6-8x faster, good enough for structured tasks)
OLLAMA_MODEL_FAST=gemma3:1b
OLLAMA_BASE_URL=http://localhost:11434

# === NCBI API Key (optional, increases PubMed rate from 3 to 10 req/sec) ===
NCBI_API_KEY=

# === Legacy (not used with Ollama, kept for compatibility) ===
GEMINI_API_KEY=
